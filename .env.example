# Google Drive — pick one auth method (service account file, or OAuth via /api/auth/google)

# Service account JSON path (share PARENT and OUTPUT folders with the SA email)
GOOGLE_SERVICE_ACCOUNT_PATH=./service_account.json

# Or OAuth (set these and visit /api/auth/google once)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# GOOGLE_OAUTH_TOKEN_PATH=./.tokens/google-oauth.json

# Folder IDs (optional here if you always pass them in the UI)
PARENT_FOLDER_ID=
OUTPUT_FOLDER_ID=

# Input formats (paste or load .csv / .txt in the UI):
# - CSV: columns name, SKU, optional description
# - Text: "Bundle Name | SKU1 SKU2" or SKU-only lines

# Gemini image generation (Google AI Studio API key)
GEMINI_API_KEY=
# Default: gemini-2.5-flash-image (preview / 3.x models often hit quota faster)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Reduce usage if you see quota / rate limit errors:
# GEMINI_IMAGES_PER_BUNDLE=1
# GEMINI_MAX_REFERENCE_IMAGES=8
# GEMINI_MS_BETWEEN_GENERATIONS=1200
# GEMINI_MAX_RETRIES=4
# GEMINI_RETRY_BASE_MS=2000
#
# Reduce hallucinations / unrelated products in generated images:
# GEMINI_IMAGE_TEMPERATURE=0.45
# Omit bundle name from the image prompt (Drive naming unchanged): GEMINI_IMAGE_PROMPT_INCLUDE_NAME=false
# CSV/product descriptions often cause invented items; off by default for the image prompt:
# GEMINI_IMAGE_PROMPT_INCLUDE_DESCRIPTION=true
